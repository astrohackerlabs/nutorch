# true if all elements are close (returns a JSON bool)
export def "nutorch allclose" [t2: string, --rtol: number, --atol: number]: string -> any {
  mut args = []
  if $rtol != null { $args = ($args | append ["--rtol" ($rtol | into string)]) }
